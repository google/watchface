<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:simpleType name="resourcePathType">
        <xs:annotation>
            <xs:documentation>
                Android resource name consists only of lowercase letters and numbers and "_".
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="[a-z_]+[a-z0-9_]*"/>
        </xs:restriction>
    </xs:simpleType>
</xs:schema>

